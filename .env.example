# magma-sidecar environment template.
#
# Copy to `.env.local` (gitignored) and edit for your machine, then:
#
#   set -a; source .env.local; set +a
#   cargo run --release
#
# Each variable corresponds 1:1 with a CLI flag in `src/config.rs`. CLI flags
# always win over env vars, env vars win over the defaults. Run
# `magma-sidecar --help` to see every knob.

# HTTP server bind address for `/rpc/monad`, `/health`, `/metrics`.
MAGMA_SIDECAR_BIND=127.0.0.1:8089

# Base URL of the Monad EL JSON-RPC. The sidecar forwards `/rpc/monad` here.
MAGMA_MONAD_RPC_URL=http://127.0.0.1:8080

# Unix socket for the Monad txpool IPC (`monad-eth-txpool-ipc`). Optional —
# omit to disable the reprioritizer and run as ingress-only.
#
# Local docker dev: point at the short symlink you create per-run, NOT the long
# `logs/<run>/node/mempool.sock` path (it's over the AF_UNIX 107-byte limit).
# See docs/LOCAL_DEVELOPMENT.md §1a.
#MAGMA_TXPOOL_SOCKET=/tmp/monad-mempool.sock

# Path to the tip-policy TOML (gateway allowlist + weights). Omit to fall back
# to legacy "stamp every Insert with MAGMA_TX_PRIORITY" mode.
#MAGMA_POLICY_CONFIG=./policy.local.toml

# Fallback hex priority used in legacy mode and for gateway txs whose computed
# score is exactly zero. Matches the node's `DEFAULT_TX_PRIORITY`.
MAGMA_TX_PRIORITY=0xffff

# Standard tracing-subscriber filter. `magma_sidecar=debug` surfaces the
# per-tx "reinjecting" / "skipping" lines from the IPC loop.
RUST_LOG=info,magma_sidecar=debug
