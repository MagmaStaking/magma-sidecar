#!/bin/sh
# postinst — dpkg(1) maintainer script. See `man 7 deb-postinst` for the full
# argument contract; we only handle `configure` (fresh install + upgrade).

set -e

UNIT=magma-sidecar.service
ENV_FILE=/etc/magma-sidecar/sidecar.env
ENV_EXAMPLE=/etc/magma-sidecar/sidecar.env.example
SERVICE_USER=magma-sidecar
SYSUSERS_FILE=/usr/lib/sysusers.d/magma-sidecar.conf

case "$1" in
    configure)
        # Create the dedicated, unprivileged service identity declaratively.
        # systemd-sysusers is idempotent and preserves an existing account.
        systemd-sysusers "${SYSUSERS_FILE}"

        # Seed the operator env file from the example on **first** install only.
        # `conffiles` already protects sidecar.env.example from being clobbered by
        # operator edits to sidecar.env on subsequent upgrades.
        if [ ! -e "${ENV_FILE}" ] && [ -e "${ENV_EXAMPLE}" ]; then
            cp "${ENV_EXAMPLE}" "${ENV_FILE}"
        fi
        chown "root:${SERVICE_USER}" "${ENV_FILE}"
        chmod 0640 "${ENV_FILE}"

        # Register/reload the unit with systemd, but *do not* enable it
        # automatically — operators must edit /etc/magma-sidecar/sidecar.env
        # (at minimum MAGMA_TXPOOL_SOCKET, MAGMA_NETWORK)
        # before the service is safe to start. The gateway address per network
        # is baked into the binary; there is no policy file to drop in.
        if [ -d /run/systemd/system ]; then
            systemctl --system daemon-reload >/dev/null || true
            # Honour operator's prior enable/disable state on upgrades.
            if [ -n "$2" ] && command -v deb-systemd-invoke >/dev/null 2>&1; then
                deb-systemd-invoke try-restart "${UNIT}" >/dev/null || true
            fi
        fi

        # First-install hint (`$2` empty == fresh install per dpkg(1)).
        if [ -z "$2" ]; then
            cat <<EOF

magma-sidecar installed.

The service is **not** enabled yet. Before starting it:

  1. Follow /usr/share/doc/magma-sidecar/VALIDATOR_INSTALL.md to configure
     monad-bft and monad-rpc for /var/run/monad-ipc/mempool.sock with ACLs.
  2. Edit /etc/magma-sidecar/sidecar.env and set:
       - MAGMA_NETWORK   (mainnet | testnet | localnet)
     The gateway address for each network is baked into the binary; switching
     networks is just changing MAGMA_NETWORK and restarting the service.
  3. systemctl enable --now magma-sidecar
  4. journalctl -u magma-sidecar -f

The service runs as the dedicated unprivileged User=magma-sidecar.
EOF
        fi
        ;;

    abort-upgrade|abort-remove|abort-deconfigure)
        : # nothing to do
        ;;

    *)
        echo "postinst called with unknown argument '$1'" >&2
        exit 1
        ;;
esac

exit 0
