#!/bin/sh
# prerm — runs before the package is removed/upgraded. Stop the running unit so
# the binary swap (upgrade) or removal doesn't leave a stale process around.

set -e

UNIT=magma-sidecar.service

case "$1" in
    remove|upgrade|deconfigure)
        if [ -d /run/systemd/system ] && command -v deb-systemd-invoke >/dev/null 2>&1; then
            deb-systemd-invoke stop "${UNIT}" >/dev/null || true
        fi
        ;;

    failed-upgrade)
        : # leave the service alone on failed upgrades
        ;;

    *)
        echo "prerm called with unknown argument '$1'" >&2
        exit 1
        ;;
esac

exit 0
